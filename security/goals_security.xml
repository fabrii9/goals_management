<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="0">
        <!-- Privilegio de la aplicación -->
        <record id="goals_privilege" model="res.groups.privilege">
            <field name="name">Objetivos</field>
            <field name="category_id" ref="base.module_category_productivity"/>
            <field name="sequence">50</field>
        </record>

        <!-- Grupos -->
        <record id="group_goals_user" model="res.groups">
            <field name="name">Usuario de Objetivos</field>
            <field name="privilege_id" ref="goals_privilege"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_goals_manager" model="res.groups">
            <field name="name">Manager de Objetivos</field>
            <field name="privilege_id" ref="goals_privilege"/>
            <field name="implied_ids" eval="[(4, ref('group_goals_user'))]"/>
            <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>
    </data>

    <data noupdate="1">
        <!-- Reglas de acceso por compañía -->
        <record id="rule_goals_goal_multi_company" model="ir.rule">
            <field name="name">Objetivo: multiempresa</field>
            <field name="model_id" ref="model_goals_goal"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        </record>

        <record id="rule_goals_goal_user" model="ir.rule">
            <field name="name">Objetivo: usuario solo ve sus objetivos y equipo</field>
            <field name="model_id" ref="model_goals_goal"/>
            <field name="domain_force">[
                '|', '|',
                ('user_id', '=', user.id),
                ('team_member_ids', 'in', [user.id]),
                ('create_uid', '=', user.id)
            ]</field>
            <field name="groups" eval="[(4, ref('group_goals_user'))]"/>
        </record>

        <record id="rule_goals_goal_manager" model="ir.rule">
            <field name="name">Objetivo: manager ve todo</field>
            <field name="model_id" ref="model_goals_goal"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_goals_manager'))]"/>
        </record>

        <record id="rule_goals_micro_objective_multi_company" model="ir.rule">
            <field name="name">Microobjetivo: multiempresa</field>
            <field name="model_id" ref="model_goals_micro_objective"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        </record>

        <record id="rule_goals_micro_objective_user" model="ir.rule">
            <field name="name">Microobjetivo: usuario solo ve los propios y de equipo</field>
            <field name="model_id" ref="model_goals_micro_objective"/>
            <field name="domain_force">[
                '|', '|',
                ('user_id', '=', user.id),
                ('team_member_ids', 'in', [user.id]),
                ('create_uid', '=', user.id)
            ]</field>
            <field name="groups" eval="[(4, ref('group_goals_user'))]"/>
        </record>

        <record id="rule_goals_micro_objective_manager" model="ir.rule">
            <field name="name">Microobjetivo: manager ve todo</field>
            <field name="model_id" ref="model_goals_micro_objective"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_goals_manager'))]"/>
        </record>

        <record id="rule_goals_daily_focus_user" model="ir.rule">
            <field name="name">Foco diario: solo propios</field>
            <field name="model_id" ref="model_goals_daily_focus"/>
            <field name="domain_force">[('user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="rule_goals_xp_log_user" model="ir.rule">
            <field name="name">Registro XP: solo propios</field>
            <field name="model_id" ref="model_goals_xp_log"/>
            <field name="domain_force">[('user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="rule_goals_user_badge_user" model="ir.rule">
            <field name="name">Insignia de usuario: solo propias</field>
            <field name="model_id" ref="model_goals_user_badge"/>
            <field name="domain_force">[('user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>
    </data>
</odoo>
