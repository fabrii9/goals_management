<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_goals_daily_focus_tree" model="ir.ui.view">
        <field name="name">goals.daily.focus.tree</field>
        <field name="model">goals.daily.focus</field>
        <field name="arch" type="xml">
            <list string="Focos del día" decoration-success="state == 'done'">
                <field name="sequence" widget="handle"/>
                <field name="date"/>
                <field name="name"/>
                <field name="micro_objective_id"/>
                <field name="goal_id"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_goals_daily_focus_form" model="ir.ui.view">
        <field name="name">goals.daily.focus.form</field>
        <field name="model">goals.daily.focus</field>
        <field name="arch" type="xml">
            <form string="Foco diario">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="sequence"/>
                        <field name="date"/>
                        <field name="micro_objective_id"/>
                        <field name="goal_id"/>
                        <field name="state"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_goals_daily_focus_search" model="ir.ui.view">
        <field name="name">goals.daily.focus.search</field>
        <field name="model">goals.daily.focus</field>
        <field name="arch" type="xml">
            <search string="Buscar focos diarios">
                <field name="name"/>
                <field name="date"/>
                <filter string="Hoy" name="today" domain="[('date', '=', context_today().strftime('%Y-%m-%d'))]"/>
                <filter string="Pendientes" name="pending" domain="[('state', '=', 'pending')]"/>
            </search>
        </field>
    </record>

    <record id="action_goals_daily_focus" model="ir.actions.act_window">
        <field name="name">Hoy</field>
        <field name="res_model">goals.daily.focus</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_today': 1}</field>
        <field name="search_view_id" ref="view_goals_daily_focus_search"/>
    </record>
</odoo>
