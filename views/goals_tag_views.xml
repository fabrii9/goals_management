<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_goals_tag_tree" model="ir.ui.view">
        <field name="name">goals.tag.tree</field>
        <field name="model">goals.tag</field>
        <field name="arch" type="xml">
            <list string="Etiquetas">
                <field name="name"/>
                <field name="color" widget="color_picker"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <record id="view_goals_tag_form" model="ir.ui.view">
        <field name="name">goals.tag.form</field>
        <field name="model">goals.tag</field>
        <field name="arch" type="xml">
            <form string="Etiqueta">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="color" widget="color_picker"/>
                        <field name="active" invisible="1"/>
                        <field name="company_id" groups="base.group_multi_company"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_goals_tag" model="ir.actions.act_window">
        <field name="name">Etiquetas</field>
        <field name="res_model">goals.tag</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
